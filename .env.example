# Google Gemini API key — used server-side to turn recorded speech into
# translated text. Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# ElevenLabs API key — used server-side to turn translated text back into
# speech audio. Get one at https://elevenlabs.io
ELEVENLABS_API_KEY=

# Optional: override the ElevenLabs voice used for playback.
# Defaults to "Rachel" (21m00Tcm4TlvDq8ikWAM) if unset.
ELEVENLABS_VOICE_ID=
